{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/webhook(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api|webhook|assets|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
