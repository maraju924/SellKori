rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() { return request.auth != null; }
    
    function isVerified() { 
      return isSignedIn() && request.auth.token.email_verified == true; 
    }

    function isAdmin() {
      return isVerified() && 
             (request.auth.token.email == 'maraju924@gmail.com' || 
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isMerchantOf(businessData) {
      return isSignedIn() && request.auth.uid == businessData.ownerId;
    }

    function isMerchantByBizId(businessId) {
      return isSignedIn() && (
        businessId != null && 
        exists(/databases/$(database)/documents/businesses/$(businessId)) &&
        get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Collection Routes ---

    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /businesses/{businessId} {
      allow read: if true; // Public for chat & shop
      allow write: if isAdmin() || (isOwner(incoming().ownerId) && (
        !exists(/databases/$(database)/documents/businesses/$(businessId)) || 
        isMerchantOf(existing())
      ));
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(incoming());
      
      // Merchants can see all orders for their business
      // Guests can see orders that match THEIR session ID
      allow list: if isAdmin() || 
                    (isMerchantByBizId(resource.data.businessId)) ||
                    (resource.data.sessionId != null); // Client filters by sessionId
      
      allow get: if isAdmin() || 
                   (isMerchantByBizId(resource.data.businessId)) ||
                   (resource.data.sessionId != null);

      allow update: if isAdmin() || (isMerchantByBizId(resource.data.businessId) && isValidOrder(incoming()));
      allow delete: if isAdmin() || isMerchantByBizId(resource.data.businessId);
    }

    match /customers/{customerId} {
      allow create: if isMerchantByBizId(incoming().businessId) || (incoming().id != null);
      
      // get/update allowed for guest chat or merchant
      allow get, update: if isAdmin() || (isMerchantByBizId(resource.data.businessId)) || true;
      
      // Merchant can list all customers
      allow list: if isAdmin() || isMerchantByBizId(resource.data.businessId);
    }

    match /analytics/{eventId} {
      allow create: if true; // Tracking events is public
      allow list: if isAdmin() || isMerchantByBizId(resource.data.businessId);
      allow get: if isAdmin() || isMerchantByBizId(resource.data.businessId);
    }

    match /system_config/public {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system_config/config {
      allow read, write: if isAdmin();
    }

    match /webhook_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    // --- Entity Validations ---

    function isValidOrder(data) {
      return data.businessId is string &&
             data.merchantId is string &&
             data.customerName is string &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'] &&
             (!('sessionId' in data) || data.sessionId is string);
    }
    // Logs functionality
    match /system_logs/{logId} {
      allow create: if true; // Webhook background tasks can create logs
      allow read: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.ownerId == 'system' ||
        isAdmin()
      );
    }
  }
}
