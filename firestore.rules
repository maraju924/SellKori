rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == 'maraju924@gmail.com' && request.auth.token.email_verified == true || 
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isOwner(ownerId) {
      return isAuthenticated() && request.auth.uid == ownerId;
    }

    match /webhook_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /system_config/config {
      allow read, write: if isAdmin();
    }

    match /system_config/public {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /analytics/{eventId} {
      allow create: if true;
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.businessOwnerId || isAdmin());
    }

    match /businesses/{businessId} {
      allow read: if true; // Public for chat
      allow write: if isAuthenticated() && (
        (exists(/databases/$(database)/documents/businesses/$(businessId)) && isOwner(resource.data.ownerId)) || 
        isAdmin() || 
        !exists(/databases/$(database)/documents/businesses/$(businessId))
      );
    }

    match /orders/{orderId} {
      allow create: if isValidOrder(request.resource.data);
      allow read, delete: if isAuthenticated() && (request.auth.uid == resource.data.merchantId || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.merchantId || isAdmin()) && isValidOrder(request.resource.data);
    }

    match /customers/{customerId} {
      allow create: if isAuthenticated() && (request.resource.data.businessOwnerId == request.auth.uid || isAdmin());
      allow read, delete: if isAuthenticated() && (resource.data.businessOwnerId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.businessOwnerId == request.auth.uid || isAdmin());
    }

    // Helper for order validation
    function isValidOrder(data) {
      return data.merchantId is string &&
             data.customerName is string &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'];
    }
  }
}
